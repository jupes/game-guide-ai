# Service build context — exclude everything except service/ and the two ingestion modules it imports
**/__pycache__/
**/*.pyc
**/*.pyo

# Ingestion scripts + data not needed at service runtime
ingestion/test_*.py
ingestion/*.jsonl
ingestion/*.json
ingestion/spike_*.py
ingestion/eval_*.py
ingestion/gen_*.py
ingestion/embed.py
ingestion/extract*.py
ingestion/ingest_books.py
ingestion/qa_chunks.py

# Other top-level dirs not needed at service runtime
vector-db/
spikes/
docs/

# ui/ source IS needed by Dockerfile.cloud's bun build stage (the single-container
# image). Keep it in the context but drop the heavy / generated dirs. Dockerfile.service
# never COPYs ui/, so this only enlarges its context by the small source tree.
ui/node_modules/
ui/dist/
ui/e2e-results/
ui/playwright-report/
