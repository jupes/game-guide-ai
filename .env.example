# Copy to `.env` and adjust. Never commit `.env`.
#
# Connection string for apps on the host:
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
#
# From another Compose service on the same network (future agent-service):
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@vector-db:5432/${POSTGRES_DB}

POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_change_me
POSTGRES_DB=game_guide_ai
POSTGRES_PORT=5432

# OpenAI embedding model (text-embedding-3-small or text-embedding-3-large)
# Get your key from https://platform.openai.com/api-keys
# NEVER commit the real value — copy this file to .env and fill it in there
OPENAI_API_KEY=sk-replace-me

# --- RAG tuning knobs (optional) -------------------------------------------
# All optional; shown with their defaults. The canonical source + rationale for
# each is config.py. Uncomment and adjust to tune retrieval/generation without a
# code change or redeploy.
# RAG_TOP_K=10                 # chunks the vector search returns per query
# RAG_CONTEXT_TOP_N=5          # top chunks fed to the LLM context + cited sources
# RAG_SNIPPET_MAX=240          # max chars of each source's display snippet
# RAG_FALLBACK_DISTANCE=0.42   # ipl: top-1 distance above which a filtered query retries unfiltered
# RAG_ANSWERABLE_DISTANCE=0.50 # koz: top-1 distance within which the corpus is judged answerable
# RAG_DEFAULT_MODEL=gpt-4o-mini  # OpenAI chat model for answer generation
# RAG_TEMPERATURE=0.2          # answer-generation sampling temperature
# RAG_RERANK=0                 # gated cross-encoder rerank (needs `pip install '.[rerank]'`;
#                              # in Docker: build with --build-arg INSTALL_RERANK=1)
