# Connection string for apps on the host:
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
#
# From another Compose service on the same network (future agent-service):
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@vector-db:5432/${POSTGRES_DB}

POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_change_me
POSTGRES_DB=rag_chat
